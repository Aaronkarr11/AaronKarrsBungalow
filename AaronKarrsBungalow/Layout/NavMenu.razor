<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Aaron Karr's Bungalow</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable">
    <nav class="nav flex-column navbarw">

        <!-- Home -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <!-- Collapsible Parent -->
        <div class="nav-item px-3">

            <!-- Parent clickable header -->
            <span class="nav-link d-flex justify-content-between align-items-center"
                  @onclick="ToggleHalcyonMenu"
                  style="cursor: pointer;">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> <span style="color:white">Halcyon Home Manager</span>
                <span class="bi @(showHalcyonMenu ? "bi-chevron-down" : "bi-chevron-right")"></span>

            </span>

            <!-- Nested items -->
            @if (showHalcyonMenu)
            {
                <div class="nav flex-column ms-4">
                    <div class="nav-item">
                        <NavLink class="nav-link" href="/halcyonhomemanager/overview">
                            Overview
                        </NavLink>
                    </div>

                    <div class="nav-item">
                        <NavLink class="nav-link" href="/halcyonhomemanager/privacypolicy">
                            Privacy Policy
                        </NavLink>
                    </div>
                </div>
            }
        </div>

    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private bool showHalcyonMenu = false;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void ToggleHalcyonMenu()
    {
        showHalcyonMenu = !showHalcyonMenu;
    }

    private string GetChevronClass()
    {
        return showHalcyonMenu ? "▾" : "▸";
    }
}
